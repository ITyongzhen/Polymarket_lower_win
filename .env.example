# -----------------------------
# 低概率单边模拟盘默认配置
# 直接复制为 .env 后即可运行
# -----------------------------

# 运行标识。留空会自动按时间生成
PM_RUN_ID=

# 轮询和运行时长
PM_POLL_SECONDS=5
PM_RUN_MINUTES=60

# 初始模拟资金
PM_BANKROLL_USD=200

# 交易范围
PM_SYMBOLS=btc,eth,sol,xrp,doge,bnb,hype
PM_TIMEFRAMES=5m,15m

# 日志目录。统一放在项目根目录 logs 下
PM_LOGS_ROOT=logs/paper_low_win

# 仓位与拆单
# 每个信号总目标份额
PM_SHARES_PER_SIGNAL=10
# 每次只打一笔子单，信号持续才继续加
PM_CHILD_SHARES=2
# 同币种同周期同一市场最多持有份额
PM_MAX_SHARES_PER_MARKET=10
PM_MAX_OPEN_POSITIONS=16

# 研究价格带
PM_MIN_LOW_PRICE=0.001
PM_MAX_LOW_PRICE=0.05

# 是否跳过疑似双边低价错价盘
PM_SKIP_DUAL_SIDE_PAIR_MARKETS=true
PM_DUAL_SIDE_PAIR_PRICE_CAP=0.05

# 盘前时间窗
PM_PRE_MIN_SECONDS_REMAINING=10
PM_PRE_MAX_SECONDS_REMAINING=360

# 盘后时间窗
PM_ALLOW_POST_CLOSE=true
PM_POST_MAX_SECONDS_AFTER_END=5
PM_SETTLEMENT_GRACE_SECONDS=8
# Polymarket 的结算源不一定等于 Binance K 线。
# 默认关闭盘后补单，并在临近结算时提高最小 edge 要求。
PM_BLOCK_POST_CLOSE_FOR_SOURCE_MISMATCH=true
PM_SOURCE_MISMATCH_GUARD_SECONDS=30
PM_SOURCE_MISMATCH_MIN_EDGE_POINTS_NEAR_CLOSE=0.003

# 外部价格上下文分层
PM_FLAT_MOVE_BPS=5
PM_FLAT_RANGE_BPS=15
PM_MILD_MOVE_BPS=15
PM_MILD_RANGE_BPS=30
PM_STRESS_MOVE_BPS=30
PM_STRESS_RANGE_BPS=60

# 不同阶段允许的最高买价
# 外部价格越平，允许从 0.01 放宽到 0.03
PM_PRE_FLAT_PRICE_CAP=0.05
PM_PRE_MILD_PRICE_CAP=0.04
PM_PRE_STRESS_PRICE_CAP=0.03
PM_POST_FLAT_PRICE_CAP=0.01
PM_POST_MILD_PRICE_CAP=0.015

# 错价估算模型
PM_FAIR_BASE_PROB=0.003
PM_FAIR_TIME_WEIGHT=0.015
PM_FAIR_FLAT_BONUS=0.012
PM_FAIR_CALM_BONUS=0.010
PM_FAIR_DISAGREEMENT_BONUS=0.015
PM_FAIR_REVERSAL_BONUS=0.006
PM_FAIR_POST_CLOSE_PENALTY=0.015
PM_MIN_EDGE_POINTS=0.0008

# 当前先持有到结算
PM_HOLD_TO_SETTLEMENT=true

# -----------------------------
# Chainlink Data Streams 原始报告采集
# 用于记录更接近 Polymarket 结算源的官方报告
# -----------------------------
PM_CHAINLINK_RUN_ID=
PM_CHAINLINK_LOGS_ROOT=logs/chainlink_streams
PM_CHAINLINK_API_KEY=
PM_CHAINLINK_API_SECRET=
PM_CHAINLINK_WS_ENDPOINT=wss://ws.dataengine.chain.link
PM_CHAINLINK_SYMBOLS=btc,eth,sol,xrp,doge,bnb,hype
# 可选覆盖。格式：btc=0x...,eth=0x...
PM_CHAINLINK_FEED_IDS=
PM_CHAINLINK_MAX_MESSAGES=0
PM_CHAINLINK_RECV_TIMEOUT_SECONDS=10
PM_CHAINLINK_PING_INTERVAL_SECONDS=5
PM_CHAINLINK_RECONNECT_SECONDS=2
